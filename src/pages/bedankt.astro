---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro'
---

<Layout
    title="AANMELDING ONTVANGEN — Operation Black Belt"
    description="Je aanmelding voor Operation Black Belt is ontvangen.">
    <main class="px-4 max-w-4xl mx-auto w-full py-24">

        <p class="text-t-text-dim text-xs tracking-[0.3em] mb-3">// TRANSMISSIE ONTVANGEN</p>
        <h1 class="text-4xl md:text-5xl font-black text-t-green glow-green mb-6">AANMELDING<br/>BEVESTIGD</h1>

        <div class="terminal-card p-6 rounded max-w-2xl mb-8">
            <p class="text-t-text-dim text-xs tracking-widest mb-3">&gt; STATUSRAPPORT_</p>
            <p class="text-t-green text-sm mb-4">Je aanmelding is ontvangen en verwerkt. De spelleider verdeelt de teams definitief op de dag zelf.</p>
            <p class="text-t-text text-sm">Wij zien je graag verschijnen bij:</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-2xl mb-10">
            <div class="terminal-card p-4 rounded">
                <p class="text-t-text-dim text-xs tracking-widest mb-1">WANNEER</p>
                <p class="text-t-green text-sm font-bold">Zondag 6 juli 2025</p>
                <p class="text-t-text text-xs">13:00 – 16:00 uur</p>
            </div>
            <div class="terminal-card p-4 rounded">
                <p class="text-t-text-dim text-xs tracking-widest mb-1">LOCATIE</p>
                <p class="text-t-green text-sm font-bold">Anna Paulowna</p>
                <p class="text-t-text text-xs">Sportlaan 21</p>
            </div>
            <div class="terminal-card p-4 rounded">
                <p class="text-t-text-dim text-xs tracking-widest mb-1">MEENEMEN</p>
                <p class="text-t-green text-sm font-bold">Geen telefoon</p>
                <p class="text-t-text text-xs">Comfortabele schoenen</p>
            </div>
        </div>

        <a href="/"
            class="inline-block border border-t-green text-t-green font-bold py-3 px-8 rounded text-sm tracking-widest hover:bg-t-green-muted transition-colors">
            &larr; TERUG NAAR HOME
        </a>

    </main>
    <Footer />
</Layout>

