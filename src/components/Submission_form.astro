---
---

<form name="smokkel-aanmelding" class="w-full space-y-6" action="/bedankt" method="post" data-netlify="true">
    <input type="hidden" name="subject" value="Nieuwe aanmelding Operation Black Belt (%{submissionId})" />

    <!-- Contactgegevens -->
    <div class="terminal-card p-5 rounded">
        <p class="text-t-text-dim text-xs tracking-widest mb-4">&gt; CONTACTGEGEVENS_</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-t-green text-xs tracking-widest mb-2" for="naam">NAAM</label>
                <input required
                    class="w-full bg-t-bg border border-t-border text-t-green placeholder:text-t-text-dim rounded px-4 py-2.5 text-sm focus:outline-none focus:border-t-green transition-colors"
                    id="naam" type="text" name="naam" placeholder="Voor- en achternaam" />
            </div>
            <div>
                <label class="block text-t-green text-xs tracking-widest mb-2" for="email">E-MAIL</label>
                <input required
                    class="w-full bg-t-bg border border-t-border text-t-green placeholder:text-t-text-dim rounded px-4 py-2.5 text-sm focus:outline-none focus:border-t-green transition-colors"
                    id="email" type="email" name="email" placeholder="naam@example.nl" />
            </div>
        </div>
    </div>

    <!-- Spelers -->
    <div class="terminal-card p-5 rounded">
        <p class="text-t-text-dim text-xs tracking-widest mb-4">&gt; SPELERSNAMEN_</p>
        <p class="text-t-text text-xs mb-4">Voer hieronder de namen in van alle deelnemers in jouw groep (max. 6)</p>
        <div class="space-y-3">
            {Array.from({length: 6}, (_, i) => (
                <div class="grid grid-cols-4 gap-3 items-center">
                    <div class="col-span-3">
                        <input
                            class="w-full bg-t-bg border border-t-border text-t-green placeholder:text-t-text-dim rounded px-4 py-2 text-sm focus:outline-none focus:border-t-green transition-colors"
                            type="text" name={`speler_${i + 1}`} placeholder={`Speler ${i + 1}${i === 0 ? ' (verplicht)' : ''}`}
                            {...(i === 0 ? {required: true} : {})} />
                    </div>
                    <div>
                        <input
                            class="w-full bg-t-bg border border-t-border text-t-green placeholder:text-t-text-dim rounded px-4 py-2 text-sm focus:outline-none focus:border-t-green transition-colors"
                            type="number" name={`leeftijd_${i + 1}`} placeholder="Leeftijd" min="5" max="99" />
                    </div>
                </div>
            ))}
        </div>
    </div>

    <!-- Teamvoorkeur -->
    <div class="terminal-card p-5 rounded">
        <p class="text-t-text-dim text-xs tracking-widest mb-4">&gt; TEAMVOORKEUR_</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <label class="flex items-center gap-3 p-3 border border-t-border rounded cursor-pointer hover:border-t-green hover:bg-t-green-muted transition-all group">
                <input type="radio" name="team_voorkeur" value="smokkelteam" class="accent-t-green" />
                <div>
                    <p class="text-t-green text-sm font-bold group-hover:glow-green">SMOKKELTEAM</p>
                    <p class="text-t-text-dim text-xs">Smokkelen & ontwijken</p>
                </div>
            </label>
            <label class="flex items-center gap-3 p-3 border border-t-border rounded cursor-pointer hover:border-t-red hover:bg-red-950/20 transition-all group">
                <input type="radio" name="team_voorkeur" value="politie" class="accent-t-red" />
                <div>
                    <p class="text-t-red text-sm font-bold">POLITIE</p>
                    <p class="text-t-text-dim text-xs">Patrouilleren & vangen</p>
                </div>
            </label>
            <label class="flex items-center gap-3 p-3 border border-t-border rounded cursor-pointer hover:border-t-amber hover:bg-yellow-950/20 transition-all group">
                <input type="radio" name="team_voorkeur" value="geen_voorkeur" class="accent-t-amber" checked />
                <div>
                    <p class="text-t-amber text-sm font-bold">GEEN VOORKEUR</p>
                    <p class="text-t-text-dim text-xs">Spelleider bepaalt</p>
                </div>
            </label>
        </div>
    </div>

    <!-- Opmerkingen -->
    <div class="terminal-card p-5 rounded">
        <p class="text-t-text-dim text-xs tracking-widest mb-4">&gt; AANVULLENDE_INFO_</p>
        <textarea
            class="w-full bg-t-bg border border-t-border text-t-green placeholder:text-t-text-dim rounded px-4 py-2.5 text-sm focus:outline-none focus:border-t-green transition-colors resize-none"
            name="opmerkingen" rows="3" placeholder="Bijzonderheden, allergieën, vragen..."></textarea>
    </div>

    <button type="submit"
        class="w-full bg-t-green text-t-bg font-bold py-3 px-6 rounded text-sm tracking-widest hover:bg-t-green-dim transition-colors glow-green">
        &gt; AANMELDING VERZENDEN_
    </button>
</form>
